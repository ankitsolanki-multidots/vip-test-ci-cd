# Files and directories to exclude from deployment

# Development and other files not needed in production
.editorconfig
.gitignore
composer.json
composer.lock
readme.txt
README.md
LICENSE
license.txt
webpack.config.js

# PHP CodeSniffer configs
.phpcs.xml
phpcs.xml
.phpcs.xml.dist
phpcs.xml.dist

# PHPUnit test configs
phpunit.xml
phpunit.xml.dist

# Environment file (contains secrets)
.env

# Development directories
.cursor/
.devcontainer/
.git/
.github/
.vscode/
.wpvip/
node_modules/
tests/
docs/
/config/

# Theme asset tooling (production uses compiled files in assets/build/)
themes/*/assets/src/
themes/*/assets/bin/
themes/*/assets/node_modules/
themes/*/assets/package.json
themes/*/assets/package-lock.json
themes/*/assets/webpack.config.js
themes/*/assets/postcss.config.js
themes/*/assets/.eslintrc.json
themes/*/assets/.eslintignore
themes/*/assets/.stylelintrc.json
themes/*/assets/.nvmrc
themes/*/assets/.npmrc
